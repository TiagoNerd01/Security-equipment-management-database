--Funcao de alerta para registros de tamanho errado
CREATE OR REPLACE FUNCTION fn_validar_tamanho_epi()
RETURNS TRIGGER AS $$
DECLARE
    v_id_tamanho_estoque INT;
    v_desc_tamanho_estoque VARCHAR(50);
    v_id_tamanho_funcionario INT;
    v_desc_tamanho_funcionario VARCHAR(50);
BEGIN
    -- Busca o tamanho do EPI que está sendo entregue (através do estoque)
    SELECT e.id_tamanho, t.descricao 
    INTO v_id_tamanho_estoque, v_desc_tamanho_estoque
    FROM estoque e
    JOIN tamanho t ON e.id_tamanho = t.id
    WHERE e.id = NEW.id_estoque;

    -- Busca o tamanho padrão do funcionário cadastrado no perfil
    SELECT f.id_tamanho_padrao, t.descricao 
    INTO v_id_tamanho_funcionario, v_desc_tamanho_funcionario
    FROM funcionario f
    LEFT JOIN tamanho t ON f.id_tamanho_padrao = t.id
    WHERE f.id = NEW.id_funcionario;

    -- Verifica se o funcionário tem um tamanho cadastrado e se é diferente do que está sendo entregue
    IF v_id_tamanho_funcionario IS NOT NULL AND v_id_tamanho_estoque != v_id_tamanho_funcionario THEN
        
        -- Emite um alerta (Warning) no log do console do banco de dados
        RAISE WARNING 'ALERTA: O tamanho do EPI entregue (%) difere do perfil do funcionário (%)', v_desc_tamanho_estoque, v_desc_tamanho_funcionario;
        
        -- Registra o alerta na tabela de auditoria
        INSERT INTO alerta_tamanho_incompativel (id_entrega, id_funcionario, tamanho_entregue, tamanho_perfil)
        VALUES (NEW.id, NEW.id_funcionario, v_desc_tamanho_estoque, v_desc_tamanho_funcionario);
        
    END IF;

    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- DROP PROCEDURE public.registrarentregaepi();

CREATE OR REPLACE PROCEDURE RegistrarEntregaEPI(
    p_data_entrega DATE,
    p_id_funcionario INT,
    p_quantidade INT,
    p_id_usuario INT,
    p_id_estoque INT
)
LANGUAGE plpgsql
AS $$
BEGIN
    -- Verifica se há saldo suficiente antes de tentar registrar
    IF (SELECT quantidade_disponivel FROM estoque WHERE id = p_id_estoque) < p_quantidade THEN
        RAISE EXCEPTION 'Saldo insuficiente no estoque para o item solicitado.';
    END IF;

    -- Registra a entrega na tabela entrega_epi
    INSERT INTO entrega_epi (data_entrega, id_funcionario, quantidade_entregue, id_usuario_registro, id_estoque)
    VALUES (p_data_entrega, p_id_funcionario, p_quantidade, p_id_usuario, p_id_estoque);

    -- Abate a quantidade do estoque
    UPDATE estoque
    SET quantidade_disponivel = quantidade_disponivel - p_quantidade
    WHERE id = p_id_estoque;

END;
$$;
;